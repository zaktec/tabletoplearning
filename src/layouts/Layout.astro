---
import '../styles/global.css';

const { title = 'TableTopLearning' } = Astro.props;
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Structured online courses across core academic and technology subjects, with clear learning pathways and tutor support." />
    <title>{title} | TableTopLearning</title>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={base}>
        <span class="brand-mark" aria-hidden="true">TTL</span>
        <span class="brand-text">TableTopLearning</span>
      </a>

      <div class="nav-shell">
        <nav class="nav-links" id="site-nav" aria-label="Primary navigation">
          <a href={`${base}#subjects`}>Subjects</a>
          <a href={`${base}#learning-pathways`}>Learning Pathways</a>
          <a href={`${base}#how-it-works`}>How It Works</a>
          <a href={`${base}#pricing`}>Pricing</a>
          <a class="nav-login" href={`${base}login`}>Learner Login</a>
          <a class="header-cta" href={`${base}courses`}>Explore Courses</a>
        </nav>

        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open navigation menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-grid">
        <div class="footer-brand">
          <a class="brand" href={base}>
            <span class="brand-mark" aria-hidden="true">TTL</span>
            <span class="brand-text">TableTopLearning</span>
          </a>
          <p>Structured online courses for core academic and technology subjects.</p>
        </div>

        <div class="footer-group">
          <h2>Courses</h2>
          <a href={`${base}subjects/mathematics`}>Maths</a>
          <a href={`${base}subjects/computer-science`}>Python Coding</a>
          <a href={`${base}subjects/computer-science`}>Computer Science</a>
          <a href={`${base}subjects/ai-machine-learning`}>AI Foundations</a>
        </div>

        <div class="footer-group">
          <h2>Information</h2>
          <a href={`${base}#learning-pathways`}>Learning Pathways</a>
          <a href={`${base}#how-it-works`}>How It Works</a>
          <a href={`${base}about`}>About</a>
          <a href={`${base}contact`}>Contact</a>
        </div>

        <div class="footer-group">
          <h2>Support</h2>
          <a href={`${base}login`}>Learner Login</a>
          <a href={`${base}#faqs`}>FAQs</a>
          <a href={`${base}privacy`}>Privacy Policy</a>
          <a href={`${base}safeguarding`}>Safeguarding</a>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; 2026 TableTopLearning</p>
        <p class="footer-credit">Technology by ZakTec Solutions</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.menu-toggle');
      const nav = document.querySelector('#site-nav');
      const body = document.body;

      const setMenuState = (isOpen: boolean) => {
        toggle?.setAttribute('aria-expanded', String(isOpen));
        toggle?.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
        nav?.classList.toggle('is-open', isOpen);
        body.classList.toggle('menu-open', isOpen);
      };

      if (toggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          setMenuState(!expanded);
        });

        nav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            setMenuState(false);
          });
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
            setMenuState(false);
            toggle.focus();
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 900) {
            setMenuState(false);
          }
        });
      }
    </script>
  </body>
</html>
