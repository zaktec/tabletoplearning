---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy">
  <section class="section">
    <div class="section-heading">
      <h1>Privacy</h1>
      <p>Contact us with a privacy question or personal-data request.</p>
    </div>

    <div class="card" style="max-width: 720px;">
      <h2>Privacy enquiries</h2>
      <p>Email <a href="mailto:hello@tabletoplearning.com?subject=Privacy%20enquiry"><strong>hello@tabletoplearning.com</strong></a> and include enough detail for the team to respond to your request.</p>
    </div>
  </section>
</Layout>
