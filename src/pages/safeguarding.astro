---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Safeguarding">
  <section class="section">
    <div class="section-heading">
      <h1>Safeguarding</h1>
      <p>Tell us if you have a safeguarding concern connected with TableTopLearning.</p>
    </div>

    <div class="card" style="max-width: 720px;">
      <h2>Report a concern</h2>
      <p>Email <a href="mailto:hello@tabletoplearning.com?subject=Safeguarding%20concern"><strong>hello@tabletoplearning.com</strong></a>. If someone is in immediate danger, contact the appropriate emergency service.</p>
    </div>
  </section>
</Layout>
