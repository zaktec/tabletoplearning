---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Learner login">
  <section class="section">
    <div class="section-heading">
      <h2>Learner login</h2>
      <p>Access your courses, progress updates and tutor support from your learner account.</p>
    </div>

    <div class="card" style="max-width: 640px; margin-top: 1rem;">
      <p>This area can be connected to a real authentication system later. For now, it provides a clear destination for learners who want to sign in.</p>
      <p style="margin-top: 0.75rem;">Browsing subjects and courses does not require an account.</p>
    </div>
  </section>
</Layout>
