---
import Layout from '../layouts/Layout.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">GCSE, A-LEVEL &amp; ADULT LEARNING</p>
      <h1>Structured courses with support when you need it.</h1>
      <p>
        Work through weekly lessons, guided practice and helpful tutor feedback at your own pace.
      </p>
      <div class="actions">
        <a class="button primary" href="#subjects">Choose a subject</a>
        <a class="button secondary" href="#pricing">Compare plans</a>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="section">
    <div class="section-heading">
      <h2>How online support works</h2>
      <p>Choose a course, work through weekly lessons and get the level of tutor support that suits you.</p>
    </div>
    <div class="step-list">
      <article class="step-card">
        <span class="step-number">1</span>
        <h3>Choose a course</h3>
        <p>Select a subject and level that matches your learning goal.</p>
      </article>
      <article class="step-card">
        <span class="step-number">2</span>
        <h3>Learn week by week</h3>
        <p>Complete lessons, quizzes and practice tasks at your own pace.</p>
      </article>
      <article class="step-card">
        <span class="step-number">3</span>
        <h3>Get tutor support</h3>
        <p>Receive feedback and join live support included in your plan.</p>
      </article>
    </div>
  </section>

  <section id="subjects" class="section">
    <div class="section-heading">
      <h2>Choose your subject</h2>
      <p>Start with the subject that fits your next step.</p>
    </div>
    <div class="subject-grid">
      <a class="subject-card" href={`${base}subjects/mathematics`} aria-label="View Mathematics courses">
        <span class="subject-icon" aria-hidden="true">📐</span>
        <h3>Mathematics</h3>
        <p>GCSE, Functional Skills and A-level support.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/computer-science`} aria-label="View Computer Science courses">
        <span class="subject-icon" aria-hidden="true">💻</span>
        <h3>Computer Science</h3>
        <p>Programming, theory and revision support.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/ai-machine-learning`} aria-label="View AI and Machine Learning courses">
        <span class="subject-icon" aria-hidden="true">🤖</span>
        <h3>AI &amp; Machine Learning</h3>
        <p>Beginner-friendly AI concepts and practical projects.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/english`} aria-label="View English course information (coming soon)">
        <span class="subject-icon" aria-hidden="true">📚</span>
        <span class="subject-status">Coming soon</span>
        <h3>English</h3>
        <p>Reading, writing and exam preparation.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/biology`} aria-label="View Biology course information (coming soon)">
        <span class="subject-icon" aria-hidden="true">🧬</span>
        <span class="subject-status">Coming soon</span>
        <h3>Biology</h3>
        <p>Core topics, practical knowledge and revision.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/physics`} aria-label="View Physics course information (coming soon)">
        <span class="subject-icon" aria-hidden="true">⚛️</span>
        <span class="subject-status">Coming soon</span>
        <h3>Physics</h3>
        <p>Core principles, equations and exam practice.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/chemistry`} aria-label="View Chemistry course information (coming soon)">
        <span class="subject-icon" aria-hidden="true">🧪</span>
        <span class="subject-status">Coming soon</span>
        <h3>Chemistry</h3>
        <p>Key concepts, calculations and revision.</p>
      </a>
      <a class="subject-card" href={`${base}subjects/languages`} aria-label="View Religion and Languages course information (coming soon)">
        <span class="subject-icon" aria-hidden="true">🗣️</span>
        <span class="subject-status">Coming soon</span>
        <h3>Religion &amp; Languages</h3>
        <p>Religion, speaking, writing and grammar support.</p>
      </a>
    </div>
  </section>

  <section class="section testimonials-section">
    <div class="section-heading">
      <h2>What learners say</h2>
      <p>Small steps, steady progress and better confidence.</p>
    </div>
    <div class="testimonial-grid">
      <article class="testimonial-card">
        <p>“The lessons were clear and the tutor feedback helped me stay focused.”</p>
        <strong>Maya, GCSE English learner</strong>
      </article>
      <article class="testimonial-card">
        <p>“The progress updates made revision feel manageable and less stressful.”</p>
        <strong>James, parent of a Year 10 learner</strong>
      </article>
    </div>
  </section>

  <section id="pricing" class="section pricing-section">
    <div class="section-heading">
      <h2>Compare Bronze, Silver and Gold</h2>
      <p>Monthly plans with no long-term contract. Choose the level of tutor support that suits you.</p>
    </div>
    <div class="pricing-grid">
      <article class="pricing-card">
        <p class="pricing-label">BRONZE — SELF-PACED</p>
        <h3>Self-paced learning</h3>
        <p class="price">£19<span>/month</span></p>
        <p class="pricing-copy">For independent learners who want structure and light support.</p>
        <ul>
          <li>One selected course</li>
          <li>Weekly lessons and practice</li>
          <li>Progress tracking</li>
          <li>Tutor-monitored progress</li>
        </ul>
        <a class="button secondary" href={`${base}courses`}>Choose Bronze</a>
      </article>

      <article class="pricing-card featured">
        <span class="badge">Most popular</span>
        <p class="pricing-label">SILVER — GUIDED</p>
        <h3>Guided learning</h3>
        <p class="price">£49<span>/month</span></p>
        <p class="pricing-copy">For learners who want regular guidance and personalised help.</p>
        <ul>
          <li>Everything in Bronze</li>
          <li>One live lesson each month</li>
          <li>Personalised practice</li>
          <li>Monthly tutor review</li>
        </ul>
        <a class="button primary" href={`${base}courses`}>Choose Silver</a>
      </article>

      <article class="pricing-card">
        <p class="pricing-label">GOLD — TUTOR-SUPPORTED</p>
        <h3>Tutor-supported learning</h3>
        <p class="price">£89<span>/month</span></p>
        <p class="pricing-copy">For learners who need more regular support or exam preparation.</p>
        <ul>
          <li>Everything in Silver</li>
          <li>Two live lessons each month</li>
          <li>Priority tutor support</li>
          <li>Personalised learning plan</li>
        </ul>
        <a class="button secondary" href={`${base}courses`}>Choose Gold</a>
      </article>
    </div>
    <p class="pricing-note">Cancel anytime. No long-term contract.</p>
  </section>

  <section class="section faq-section">
    <div class="section-heading">
      <h2>Frequently asked questions</h2>
      <p>Helpful answers before you choose a course.</p>
    </div>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-1" data-faq-toggle>
          Do I need an account to browse?
          <span aria-hidden="true">+</span>
        </button>
        <div id="faq-1" class="faq-answer" hidden>
          <p>No. You can browse subjects and courses without an account. You only need an account when you are ready to enrol.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-2" data-faq-toggle>
          Which plans include tutor support?
          <span aria-hidden="true">+</span>
        </button>
        <div id="faq-2" class="faq-answer" hidden>
          <p>Silver and Gold include live tutor support and personalised feedback. Bronze is mainly self-paced.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-3" data-faq-toggle>
          Can I cancel or change my plan?
          <span aria-hidden="true">+</span>
        </button>
        <div id="faq-3" class="faq-answer" hidden>
          <p>Yes. Monthly plans can be cancelled or changed from your learner account.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <h2>Start with the subject that fits your goals</h2>
    <p>Explore subjects and choose the support level that suits you.</p>
    <div class="actions">
      <a class="button primary" href="#subjects">Browse subjects</a>
      <a class="button secondary" href="#pricing">Compare plans</a>
    </div>
  </section>
</Layout>

<script>
  const faqButtons = document.querySelectorAll('[data-faq-toggle]');

  faqButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const item = button.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const isOpen = button.getAttribute('aria-expanded') === 'true';

      if (item && answer instanceof HTMLElement) {
        item.classList.toggle('is-open', !isOpen);
        button.setAttribute('aria-expanded', String(!isOpen));
        answer.hidden = isOpen;
      }
    });
  });
</script>
