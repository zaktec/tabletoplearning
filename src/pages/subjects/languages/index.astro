---
import Layout from '../../../layouts/Layout.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const title = 'Religion & Languages';
const description = 'Support for religion, speaking, writing and grammar through structured weekly learning.';
const courses = [
  {
    title: 'Religion & Languages Learning Pathway',
    description: 'A clear route through key ideas, vocabulary, grammar and written practice.',
    href: `${base}courses/languages`,
  },
];
---

<Layout title={title}>
  <section class="section">
    <div class="section-heading">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="subject-page-intro">
      <p>Support religion and language learning through clear tasks, regular review and feedback that helps build confidence over time.</p>
      <ul class="feature-list">
        <li>Grammar and vocabulary practice in manageable steps</li>
        <li>Writing and speaking support that grows with the learner</li>
        <li>Guidance that helps maintain steady progress</li>
      </ul>
    </div>

    <div class="card-grid" style="margin-top: 1rem;">
      {courses.map((course) => (
        <a class="card" href={course.href}>
          <h3>{course.title}</h3>
          <p>{course.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
