---
import Layout from '../../../layouts/Layout.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const title = 'AI & Machine Learning';
const description = 'Support for learners exploring modern concepts through clear, structured study.';
const courses = [
  {
    title: 'AI Learning Pathway',
    description: 'Explore core concepts and practical examples with guidance at a steady pace.',
    href: `${base}courses/ai-machine-learning`,
  },
];
---

<Layout title={title}>
  <section class="section">
    <div class="section-heading">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="subject-page-intro">
      <p>Introduce important ideas in a logical sequence and build confidence through guided lessons and practice.</p>
      <ul class="feature-list">
        <li>Clear explanations of key concepts</li>
        <li>Structured practice to build understanding</li>
        <li>Support that keeps learning focused and manageable</li>
      </ul>
    </div>

    <div class="card-grid" style="margin-top: 1rem;">
      {courses.map((course) => (
        <a class="card" href={course.href}>
          <h3>{course.title}</h3>
          <p>{course.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
