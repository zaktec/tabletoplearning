---
import Layout from '../../../layouts/Layout.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const title = 'Mathematics';
const description = 'Structured support for learners who need clear weekly guidance, practice and tutor feedback.';
const courses = [
  {
    title: 'GCSE Foundation Maths',
    description: 'Confidence-building lessons for grades 4 to 5 with structured revision and exam practice.',
    href: `${base}courses/mathematics`,
  },
  {
    title: 'GCSE Higher Maths',
    description: 'Higher-level topics, problem solving and exam support for grades 6 to 9.',
    href: `${base}courses/mathematics`,
  },
  {
    title: 'A-Level Maths',
    description: 'Focused support for pure maths, statistics and mechanics at sixth-form level.',
    href: `${base}courses/mathematics`,
  },
];
---

<Layout title={title}>
  <section class="section">
    <div class="section-heading">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="subject-page-intro">
      <p>Choose a course pathway that matches the learner’s level, then follow a weekly structure with tutor review and progress support.</p>
      <ul class="feature-list">
        <li>One selected course or pathway level at a time</li>
        <li>Weekly lesson release to keep learning steady</li>
        <li>Tutor monitoring and feedback in every plan</li>
      </ul>
    </div>

    <div class="card-grid" style="margin-top: 1rem;">
      {courses.map((course) => (
        <a class="card" href={course.href}>
          <h3>{course.title}</h3>
          <p>{course.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
