---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Events">
  <section class="section">
    <h2>Upcoming events</h2>
    <div class="card-grid">
      <div class="card">
        <h3>Workshop Week</h3>
        <p>Join hands-on sessions focused on interactive storytelling and digital creativity.</p>
      </div>
      <div class="card">
        <h3>Community Showcase</h3>
        <p>Celebrate projects and connect with learners, mentors, and partners.</p>
      </div>
    </div>
  </section>
</Layout>
